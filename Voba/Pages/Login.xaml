<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Voba.Pages.Login"
             Shell.NavBarIsVisible="False"
                         BackgroundColor="#f1ebe1">

    <ScrollView>
        <VerticalStackLayout Padding="36,60,36,36" Spacing="0">

            <!-- Back -->
            <Button Text="Back"
                    BackgroundColor="Transparent"
                    TextColor="#8ba888"
                    FontSize="14"
                    HorizontalOptions="Start"
                    Padding="0"
                    BorderWidth="0"
                    Clicked="OnBackClicked"
                    Margin="0,0,0,32" />

            <!-- Heading -->
            <Label Text="Welcome back"
                   FontSize="34"
                   FontAttributes="Bold"
                   TextColor="#2e4d2c"
                   Margin="0,0,0,6" />

            <Label Text="Log in to continue"
                   FontSize="15"
                   TextColor="#6e9e6c"
                   Margin="0,0,0,40" />

            <!-- Email -->
            <Label Text="EMAIL" FontSize="11" FontAttributes="Bold"
                   CharacterSpacing="1.5" TextColor="#8ba888" Margin="0,0,0,6" />
            <Border Stroke="#c8bfb4" StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    Padding="14,0" Margin="0,0,0,20">
                <Entry x:Name="EmailEntry"
                       Placeholder="you@example.com"
                       Keyboard="Email"
                       BackgroundColor="Transparent"
                       TextColor="#2e4d2c"
                       PlaceholderColor="#b0a898"
                       FontSize="15"
                       HeightRequest="48" />
            </Border>

            <!-- Password -->
            <Label Text="PASSWORD" FontSize="11" FontAttributes="Bold"
                   CharacterSpacing="1.5" TextColor="#8ba888" Margin="0,0,0,6" />
            <Border Stroke="#c8bfb4" StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    Padding="14,0" Margin="0,0,0,36">
                <Entry x:Name="PasswordEntry"
                       Placeholder="Your password"
                       IsPassword="True"
                       BackgroundColor="Transparent"
                       TextColor="#2e4d2c"
                       PlaceholderColor="#b0a898"
                       FontSize="15"
                       HeightRequest="48" />
            </Border>

            <!-- Error message -->
            <Label x:Name="ErrorLabel"
                   Text=""
                   TextColor="#c0392b"
                   FontSize="13"
                   IsVisible="False"
                   Margin="0,0,0,16" />

            <!-- Login button -->
            <Button Text="LOG IN"
                    BackgroundColor="#8ba888"
                    TextColor="#f1ebe1"
                    FontSize="15"
                    FontAttributes="Bold"
                    CharacterSpacing="2"
                    CornerRadius="10"
                    HeightRequest="52"
                    Clicked="OnLoginClicked"
                    Margin="0,0,0,20" />

            <!-- Switch to sign up -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                <Label Text="Don't have an account?"
                       FontSize="14" TextColor="#8a8078" />
                <Label Text="Sign up"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="#8ba888"
                       TextDecorations="Underline">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSignUpTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>