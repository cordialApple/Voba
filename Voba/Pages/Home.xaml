<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Voba.Pages.Home"
             Title="Voba"
             BackgroundColor="#f1ebe1">

    <Shell.NavBarIsVisible>False</Shell.NavBarIsVisible>

    <Grid RowDefinitions="Auto, *">

        <Grid Grid.Row="0" BackgroundColor="#8ba888" Padding="20,50,20,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                <Label Text="Voba" FontSize="28" FontAttributes="Bold"
                       TextColor="White" FontFamily="OpenSansSemibold"/>
                <Label Text="AI-powered recipe generation" FontSize="12"
                       TextColor="#dceadc" Margin="0,2,0,0" FontFamily="OpenSansRegular"/>
            </VerticalStackLayout>
            <Frame Grid.Column="1" WidthRequest="44" HeightRequest="44"
                   CornerRadius="22" BorderColor="#f1ebe1" Padding="0"
                   HasShadow="False" VerticalOptions="Center" IsClippedToBounds="True">
                <Image Source="vobaPfp.png" Aspect="AspectFill"
                       WidthRequest="44" HeightRequest="44"/>
            </Frame>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,36,24,40" Spacing="20">

                <Label Text="What would you like to do?" FontSize="20"
                       FontAttributes="Bold" TextColor="#4a6b47"
                       FontFamily="OpenSansSemibold" HorizontalOptions="Center"
                       Margin="0,0,0,10"/>

                <!-- Create New -->
                <Frame BackgroundColor="#e8f0e8" CornerRadius="20"
                       BorderColor="#c5d9c4" Padding="0" HasShadow="False" HeightRequest="190">
                    <Grid>
                        <Ellipse Fill="#c5d9c4" WidthRequest="130" HeightRequest="130"
                                 HorizontalOptions="End" VerticalOptions="End"
                                 Margin="0,0,-35,-35"/>
                        <VerticalStackLayout Padding="28,24,28,24" VerticalOptions="Center">
                            <Frame BackgroundColor="#8ba888" CornerRadius="14"
                                   WidthRequest="52" HeightRequest="52" Padding="0"
                                   HasShadow="False" HorizontalOptions="Start" Margin="0,0,0,14">
                                <Label Text="✏️" FontSize="24"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Frame>
                            <Label Text="Create New" FontSize="22" FontAttributes="Bold"
                                   TextColor="#4a6b47" FontFamily="OpenSansSemibold"/>
                            <Label Text="Generate a new AI recipe" FontSize="14"
                                   TextColor="#6a8a67" Margin="0,4,0,0" FontFamily="OpenSansRegular"/>
                        </VerticalStackLayout>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCreateNewTapped"/>
                        </Grid.GestureRecognizers>
                    </Grid>
                </Frame>

                <!-- Saved -->
                <Frame BackgroundColor="#edf4ed" CornerRadius="20"
                       BorderColor="#c5d9c4" Padding="0" HasShadow="False" HeightRequest="190">
                    <Grid>
                        <Ellipse Fill="#b0c9af" WidthRequest="130" HeightRequest="130"
                                 HorizontalOptions="End" VerticalOptions="End"
                                 Margin="0,0,-35,-35"/>
                        <VerticalStackLayout Padding="28,24,28,24" VerticalOptions="Center">
                            <Frame BackgroundColor="#6a8a67" CornerRadius="14"
                                   WidthRequest="52" HeightRequest="52" Padding="0"
                                   HasShadow="False" HorizontalOptions="Start" Margin="0,0,0,14">
                                <Label Text="🔖" FontSize="24"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Frame>
                            <Label Text="Saved" FontSize="22" FontAttributes="Bold"
                                   TextColor="#4a6b47" FontFamily="OpenSansSemibold"/>
                            <Label Text="Browse your saved recipes" FontSize="14"
                                   TextColor="#6a8a67" Margin="0,4,0,0" FontFamily="OpenSansRegular"/>
                        </VerticalStackLayout>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSavedTapped"/>
                        </Grid.GestureRecognizers>
                    </Grid>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
