<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Voba.Pages.Home"
             Title="Voba"
             BackgroundColor="#f1ebe1">

    <Shell.NavBarIsVisible>False</Shell.NavBarIsVisible>

    <Grid RowDefinitions="Auto, *">

        <Grid Grid.Row="0" BackgroundColor="#8ba888" Padding="20,50,20,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                <Label Text="Voba" FontSize="28" FontAttributes="Bold"
                       TextColor="White" FontFamily="OpenSansSemibold"/>
            </VerticalStackLayout>

        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,36,24,40" Spacing="20">

                <Label Text="What would you like to do?" FontSize="20"
                       FontAttributes="Bold" TextColor="#4a6b47"
                       FontFamily="OpenSansSemibold" HorizontalOptions="Center"
                       Margin="0,0,0,10"/>


                <!-- Create New -->
                <Border BackgroundColor="#e8f0e8"
                        Stroke="#c5d9c4"
                        StrokeThickness="1"
                        Padding="0"
                        HeightRequest="190">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Grid>
                        <Ellipse Fill="#c5d9c4" WidthRequest="130" HeightRequest="130"
                                 HorizontalOptions="End" VerticalOptions="End"
                                 Margin="0,0,-35,-35"/>
                        <VerticalStackLayout Padding="28,24,28,24" VerticalOptions="Center">
                            <Label Text="Create New" FontSize="30" FontAttributes="Bold"
                                   TextColor="#4a6b47" FontFamily="OpenSansSemibold"/>
                            <Label Text="Generate a new AI recipe" FontSize="14"
                                   TextColor="#6a8a67" Margin="0,4,0,0" FontFamily="OpenSansRegular"/>
                        </VerticalStackLayout>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCreateNewTapped"/>
                        </Grid.GestureRecognizers>
                    </Grid>
                </Border>

                <!-- Saved -->
                <Border BackgroundColor="#edf4ed"
                        Stroke="#c5d9c4"
                        StrokeThickness="1"
                        Padding="0"
                        HeightRequest="190">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Grid>
                        <Ellipse Fill="#b0c9af" WidthRequest="130" HeightRequest="130"
                                 HorizontalOptions="End" VerticalOptions="End"
                                 Margin="0,0,-35,-35"/>
                        <VerticalStackLayout Padding="28,24,28,24" VerticalOptions="Center">
                            <Label Text="Saved" FontSize="30" FontAttributes="Bold"
                                   TextColor="#4a6b47" FontFamily="OpenSansSemibold"/>
                            <Label Text="Browse your saved recipes" FontSize="14"
                                   TextColor="#6a8a67" Margin="0,4,0,0" FontFamily="OpenSansRegular"/>
                        </VerticalStackLayout>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSavedTapped"/>
                        </Grid.GestureRecognizers>
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>