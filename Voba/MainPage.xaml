<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Voba.MainPage">

    <VerticalStackLayout Padding="30" Spacing="20">
        <Label Text="Gemma 3:1b Connection Test" FontSize="24" FontAttributes="Bold" />

        <Editor x:Name="PromptInput" 
                Text="Say 'Hello, Voba is connected!' and nothing else." 
                HeightRequest="60" />

        <Button x:Name="TestButton" 
                Text="Send to Localhost" 
                Clicked="OnTestButtonClicked" 
                HeightRequest="50" />

        <ActivityIndicator x:Name="LoadingSpinner" 
                           IsRunning="False" 
                           IsVisible="False" 
                           Color="Blue" />

        <Border Stroke="LightGray" Padding="15" StrokeThickness="1">
            <ScrollView HeightRequest="300">
                <Label x:Name="ResponseLabel" 
                       Text="Waiting for response..." 
                       TextColor="Gray" />
            </ScrollView>
        </Border>
    </VerticalStackLayout>

</ContentPage>