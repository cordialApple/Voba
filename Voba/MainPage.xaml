<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Voba.MainPage">

    <VerticalStackLayout Padding="30" Spacing="20">
        <Label Text="Voba Recipe Ideation" FontSize="24" FontAttributes="Bold" />

        <Entry x:Name="BudgetInput" 
               Placeholder="Target Budget (e.g., 15.00)" 
               Keyboard="Numeric" />
               
        <Entry x:Name="ServingsInput" 
               Placeholder="Serving Size (e.g., 2)" 
               Keyboard="Numeric" />
               
        <Entry x:Name="DietInput" 
               Placeholder="Dietary Restrictions (e.g., Gluten-Free, Vegan)" />

        <Button x:Name="TestButton" 
                Text="Generate Ideas" 
                Clicked="OnTestButtonClicked" 
                HeightRequest="50" />

        <ActivityIndicator x:Name="LoadingSpinner" 
                           IsRunning="False" 
                           IsVisible="False" 
                           Color="Blue" />

        <Border Stroke="LightGray" Padding="15" StrokeThickness="1">
            <ScrollView HeightRequest="300">
                <Label x:Name="ResponseLabel" 
                       Text="Waiting for input..." 
                       TextColor="Gray" />
            </ScrollView>
        </Border>
    </VerticalStackLayout>

</ContentPage>