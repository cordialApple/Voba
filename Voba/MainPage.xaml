<?xml version="1.0" encoding="utf-8" ?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Voba.MainPage">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">

            <!-- ── Title ─────────────────────────────────────────────────── -->
            <Label Text="Voba Recipe Ideation"
                   FontSize="24"
                   FontAttributes="Bold" />

            <!-- ── Inputs ─────────────────────────────────────────────────── -->
            <Entry x:Name="BudgetInput"
                   Placeholder="Target Budget (e.g., 15.00)"
                   Keyboard="Numeric" />

            <Entry x:Name="ServingsInput"
                   Placeholder="Serving Size (e.g., 2)"
                   Keyboard="Numeric" />

            <!-- Lifestyle diet checkboxes -->
            <Label Text="Lifestyle Diet" FontAttributes="Bold" />
            <FlexLayout Wrap="Wrap" Direction="Row">
                <HorizontalStackLayout Margin="0,0,16,8">
                    <CheckBox x:Name="ChkVegan" />
                    <Label Text="Vegan" VerticalOptions="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Margin="0,0,16,8">
                    <CheckBox x:Name="ChkVegetarian" />
                    <Label Text="Vegetarian" VerticalOptions="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Margin="0,0,16,8">
                    <CheckBox x:Name="ChkKeto" />
                    <Label Text="Keto" VerticalOptions="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Margin="0,0,16,8">
                    <CheckBox x:Name="ChkPaleo" />
                    <Label Text="Paleo" VerticalOptions="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Margin="0,0,16,8">
                    <CheckBox x:Name="ChkGlutenFree" />
                    <Label Text="Gluten-Free" VerticalOptions="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Margin="0,0,16,8">
                    <CheckBox x:Name="ChkDairyFree" />
                    <Label Text="Dairy-Free" VerticalOptions="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Margin="0,0,16,8">
                    <CheckBox x:Name="ChkHalal" />
                    <Label Text="Halal" VerticalOptions="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Margin="0,0,16,8">
                    <CheckBox x:Name="ChkKosher" />
                    <Label Text="Kosher" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </FlexLayout>

            <!-- Allergies -->
            <Label Text="Allergies (comma-separated, e.g. nuts, soy)" FontAttributes="Bold" />
            <Entry x:Name="AllergyInput" Placeholder="nuts, shellfish, eggs..." />

            <!-- Cuisine -->
            <Label Text="Cuisine (optional, e.g. Italian, Thai, Mexican)" FontAttributes="Bold" />
            <Entry x:Name="CuisineInput" Placeholder="Leave blank for any cuisine..." />

            <!-- Generate button -->
            <Button x:Name="TestButton"
                    Text="Generate Ideas"
                    Clicked="OnGenerateClicked"
                    HeightRequest="50" />

            <ActivityIndicator x:Name="LoadingSpinner"
                               IsRunning="False"
                               IsVisible="False"
                               Color="Blue" />

            <!-- ── Debug prompt panel ─────────────────────────────────────── -->
            <Label x:Name="PromptDebugHeader"
                   Text="▶ PROMPT SENT TO GEMMA"
                   FontSize="12"
                   FontAttributes="Bold"
                   TextColor="Gray"
                   IsVisible="False" />

            <Border x:Name="PromptDebugBorder"
                    Stroke="#AAAAAA"
                    StrokeThickness="1"
                    Padding="15"
                    IsVisible="False">
                <ScrollView HeightRequest="200">
                    <Label x:Name="PromptDebugLabel"
                           FontFamily="Courier New"
                           FontSize="11"
                           TextColor="DarkSlateGray" />
                </ScrollView>
            </Border>

            <!-- ── Recipe cards (hidden until ideas are returned) ─────────── -->
            <VerticalStackLayout x:Name="RecipeCardsPanel"
                                 IsVisible="False"
                                 Spacing="16">

                <Label Text="◀ RECIPE IDEAS"
                       FontSize="12"
                       FontAttributes="Bold"
                       TextColor="Gray" />

                <!-- Card 1 -->
                <Border x:Name="Card1"
                        Stroke="#CCCCCC"
                        StrokeThickness="1"
                        Padding="16"
                        IsVisible="False">
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="Card1Title"
                               FontSize="16"
                               FontAttributes="Bold" />
                        <Label x:Name="Card1Ingredients"
                               FontSize="13"
                               TextColor="DarkSlateGray" />
                        <Label x:Name="Card1Cost"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="SeaGreen" />
                        <Label x:Name="Card1TotalCost"
                               FontSize="13"
                               TextColor="SeaGreen" />
                        <Button x:Name="SelectBtn1"
                                Text="Cook This Recipe"
                                Clicked="OnSelectRecipe1Clicked"
                                HeightRequest="44" />
                    </VerticalStackLayout>
                </Border>

                <!-- Card 2 -->
                <Border x:Name="Card2"
                        Stroke="#CCCCCC"
                        StrokeThickness="1"
                        Padding="16"
                        IsVisible="False">
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="Card2Title"
                               FontSize="16"
                               FontAttributes="Bold" />
                        <Label x:Name="Card2Ingredients"
                               FontSize="13"
                               TextColor="DarkSlateGray" />
                        <Label x:Name="Card2Cost"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="SeaGreen" />
                        <Label x:Name="Card2TotalCost"
                               FontSize="13"
                               TextColor="SeaGreen" />
                        <Button x:Name="SelectBtn2"
                                Text="Cook This Recipe"
                                Clicked="OnSelectRecipe2Clicked"
                                HeightRequest="44" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>

            <!-- ── Cooking instructions panel (hidden until recipe selected) -->
            <VerticalStackLayout x:Name="InstructionsPanel"
                                 IsVisible="False"
                                 Spacing="12">

                <BoxView HeightRequest="1"
                         Color="#DDDDDD"
                         Margin="0,8,0,8" />

                <Label Text="◀ COOKING INSTRUCTIONS"
                       FontSize="12"
                       FontAttributes="Bold"
                       TextColor="Gray" />

                <ActivityIndicator x:Name="InstructionsSpinner"
                                   IsRunning="False"
                                   IsVisible="False"
                                   Color="Blue" />

                <Label x:Name="InstructionsTitle"
                       FontSize="18"
                       FontAttributes="Bold" />

                <Border Stroke="LightGray"
                        StrokeThickness="1"
                        Padding="16">
                    <Label x:Name="InstructionsLabel"
                           FontSize="14"
                           LineBreakMode="WordWrap" />
                </Border>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
